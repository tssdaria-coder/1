{%- comment -%}
  Viewport-fixed sticky Add-to-Cart bar for product pages.
  Appears (slides up) when the in-page ATC scrolls out of view.
  Liquid-glass styling: translucent + backdrop-blur.
  JS-hardened: re-parents itself to document.body and applies inline
  fixed-positioning styles so no ancestor containing block can break it.
{%- endcomment -%}

{%- if product != blank -%}
  {%- assign current_variant = product.selected_or_first_available_variant -%}
  <reset-sticky-atc class="sticky-atc" aria-hidden="true">
    <div class="sticky-atc__inner">
      {%- if product.featured_media -%}
        <img class="sticky-atc__image"
             src="{{ product.featured_media | image_url: width: 160 }}"
             alt="" loading="lazy" width="56" height="56">
      {%- endif -%}
      <div class="sticky-atc__text">
        <p class="sticky-atc__title">{{ product.title }}</p>
        <p class="sticky-atc__price">
          {{ current_variant.price | money }}
        </p>
      </div>
      <form action="/cart/add" method="post" class="sticky-atc__form"
            data-type="add-to-cart-form">
        <input type="hidden" name="form_type" value="product">
        <input type="hidden" name="utf8" value="✓">
        <input type="hidden" name="id" value="{{ current_variant.id }}"
               class="sticky-atc__variant-id">
        <input type="hidden" name="quantity" value="1">
        <button type="submit" class="button sticky-atc__button"
                {% unless current_variant.available %}disabled{% endunless %}>
          {% if current_variant.available %}Add to cart{% else %}Sold out{% endif %}
        </button>
      </form>
    </div>
  </reset-sticky-atc>

  <script>
    if (!customElements.get('reset-sticky-atc')) {
      class ResetStickyAtc extends HTMLElement {
        connectedCallback() {
          // 1) Re-parent to <body> so no ancestor can ever create
          //    a containing block that breaks position:fixed.
          if (this.parentElement && this.parentElement !== document.body) {
            document.body.appendChild(this);
          }

          // 2) Force inline positioning that overrides every CSS source.
          Object.assign(this.style, {
            position: 'fixed',
            left: '50%',
            right: 'auto',
            top: 'auto',
            bottom: 'max(20px, env(safe-area-inset-bottom, 20px))',
            zIndex: '9999',
            width: 'min(720px, calc(100vw - 32px))',
            margin: '0',
            transform: 'translate3d(-50%, 130%, 0)',
            transition: 'transform 480ms cubic-bezier(0.22,0.61,0.36,1), opacity 320ms ease',
            opacity: '0',
            pointerEvents: 'none',
            display: 'block',
          });

          // 3) Watch the in-page ATC; reveal when it scrolls out.
          const findSentinel = () => document.querySelector(
            'product-form, .buy-buttons, [data-section-type="product-information"] form[action="/cart/add"], form[action="/cart/add"]'
          );
          const attachObserver = () => {
            this.sentinel = findSentinel();
            if (!this.sentinel) return false;
            this.observer = new IntersectionObserver(entries => {
              entries.forEach(e => {
                const visible = !e.isIntersecting;
                this.classList.toggle('sticky-atc--visible', visible);
                this.style.transform = visible
                  ? 'translate3d(-50%, 0, 0)'
                  : 'translate3d(-50%, 130%, 0)';
                this.style.opacity = visible ? '1' : '0';
                this.style.pointerEvents = visible ? 'auto' : 'none';
                this.setAttribute('aria-hidden', !visible);
              });
            }, { rootMargin: '0px 0px -40% 0px', threshold: 0 });
            this.observer.observe(this.sentinel);
            return true;
          };
          // Retry briefly in case product-form hasn't mounted yet
          if (!attachObserver()) {
            let tries = 0;
            const t = setInterval(() => {
              if (attachObserver() || ++tries > 20) clearInterval(t);
            }, 200);
          }

          // 4) Sync variant changes from Horizon's variant picker
          document.addEventListener('variant:change', e => {
            const id = e?.detail?.variant?.id;
            if (id) this.querySelector('.sticky-atc__variant-id').value = id;
          });
        }
        disconnectedCallback() { this.observer?.disconnect(); }
      }
      customElements.define('reset-sticky-atc', ResetStickyAtc);
    }
  </script>
{%- endif -%}